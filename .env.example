# {{PROJECT_NAME}} — Environment Variables
# Copy this file to .env and fill in the values.
# IMPORTANT: Do NOT add inline comments (python-dotenv reads them as values)

# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/mydb

# API Keys
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# App Config
APP_ENV=development
APP_PORT=8000
APP_DEBUG=true
